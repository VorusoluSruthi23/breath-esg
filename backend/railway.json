{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python setup_demo.py && gunicorn breathe_esg.wsgi --bind 0.0.0.0:$PORT --log-file -",
    "healthcheckPath": "/health/",
    "restartPolicyType": "ON_FAILURE"
  }
}
