{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python manage.py migrate && gunicorn breathe_esg.wsgi --bind 0.0.0.0:$PORT --workers 2 --log-file -",
    "healthcheckPath": "/health/",
    "restartPolicyType": "ON_FAILURE"
  }
}
